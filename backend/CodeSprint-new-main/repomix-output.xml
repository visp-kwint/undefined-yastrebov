                        <button class="send-btn" id="send-btn">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M1.5 9.55a1.5 1.5 0 0 0 0 3v-3zm19.06 2.56a1.5 1.5 0 0 0 0-2.12l-9.55-9.55a1.5 1.5 0 1 0-2.12 2.12L17.38 11l-8.49 8.49a1.5 1.5 0 1 0 2.12 2.12l9.55-9.55zM1.5 12.55H19.5v-3H1.5v3z" fill="#D9D9D9" fill-opacity="0.56"/></svg>
                        </button>
