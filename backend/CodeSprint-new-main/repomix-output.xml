<file path="public/main.css">
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    background-color: #1a1a1a;
    color: #e0e0e0;
    overflow: hidden;
    height: 100vh;
    height: 100dvh;
}

.container {
    display: flex;
    height: 100vh;
    height: 100dvh;
}

/* ===== SIDEBAR ===== */
.sidebar {
    width: 300px;
    background-color: #252525;
    padding: 16px;
    display: flex;
    flex-direction: column;
    border-right: 1px solid #333;
    flex-shrink: 0;
    z-index: 200;
    transition: transform 0.3s ease;
    overflow-y: auto;
}

.sidebar-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid #333;
}

.logo {
    font-size: 22px;
    font-weight: 600;
    color: #e0e0e0;
}

.logo-pro {
    color: #4ade80;
    font-weight: 700;
}

.folder-icon { font-size: 20px; }

/* ===== COMMAND PANEL ===== */
.command-panel {
    background: #2a2a2a;
    border-radius: 12px;
    padding: 14px;
    margin-bottom: 16px;
    border: 1px solid #333;
}

.panel-title {
    font-size: 12px;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 10px;
    font-weight: 600;
}

.command-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
}

.cmd-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 10px 4px;
    background: #333;
    border: 1px solid #3a3a3a;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    color: #b0b0b0;
}

.cmd-btn:hover {
    background: #3d3d3d;
    border-color: #4ade80;
    color: #e0e0e0;
    transform: translateY(-1px);
}

.cmd-btn:active {
    transform: translateY(0);
}

.cmd-icon {
    font-size: 20px;
    line-height: 1;
}

.cmd-label {
    font-size: 10px;
    text-align: center;
    line-height: 1.2;
}

/* ===== QUICK ACTIONS ===== */
.quick-actions {
    background: #2a2a2a;
    border-radius: 12px;
    padding: 14px;
    margin-bottom: 16px;
    border: 1px solid #333;
}

.action-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.action-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    background: #333;
    border: 1px solid #3a3a3a;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    color: #c0c0c0;
    font-size: 13px;
    text-align: left;
    width: 100%;
}

.action-btn:hover {
    background: #3d3d3d;
    border-color: #60a5fa;
    color: #e0e0e0;
}

.action-btn span {
    font-size: 16px;
}

/* ===== SIDEBAR NAV ===== */
.sidebar-nav ul {
    list-style: none;
    margin-bottom: 16px;
}

.sidebar-nav li {
    padding: 10px 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    color: #b0b0b0;
    transition: all 0.2s;
    user-select: none;
    border-radius: 8px;
    margin-bottom: 4px;
    font-size: 14px;
}

.sidebar-nav li:hover {
    color: #e0e0e0;
    background: #2a2a2a;
}

.sidebar-nav li:active {
    color: #ffffff;
    background: #333;
}

.sidebar-nav .icon {
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.sidebar-sections {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
}

.section { margin-bottom: 20px; }

.section h3 {
    font-size: 12px;
    color: #666;
    margin-bottom: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.history-item {
    padding: 8px 12px;
    background-color: #2a2a2a;
    border-radius: 8px;
    margin-bottom: 6px;
    cursor: pointer;
    transition: background-color 0.2s;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 6px;
    position: relative;
    border: 1px solid transparent;
}

.history-item:hover {
    background-color: #333;
    border-color: #3a3a3a;
}

.history-item-title {
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
}

.history-item-del {
    background: none;
    border: none;
    color: #666;
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    padding: 0 2px;
    border-radius: 4px;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.15s, color 0.15s;
}

.history-item:hover .history-item-del { opacity: 1; }
.history-item-del:hover { color: #ff4444; }

@media (hover: none) {
    .history-item-del { opacity: 0.5; }
}

.sidebar-footer {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 16px;
    margin-top: auto;
    border-top: 1px solid #333;
}

.sidebar-footer a {
    color: #666;
    text-decoration: none;
    font-size: 12px;
}

.sidebar-footer a:hover { color: #888; }

.sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 199;
    backdrop-filter: blur(2px);
}

.sidebar-overlay.active { display: block; }

/* ===== MAIN CONTENT ===== */
.burger-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
    color: #e0e0e0;
    transition: background 0.2s;
    flex-shrink: 0;
}

.burger-btn:hover { background: #3a3a3a; }
.burger-btn svg { display: block; }

.main-content {
    flex: 1;
    background-color: #1a1a1a;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
}

.main-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 20px;
    gap: 12px;
    flex-shrink: 0;
    border-bottom: 1px solid #2a2a2a;
}

.header-badges {
    display: flex;
    gap: 8px;
    align-items: center;
}

.badge {
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.badge-pro {
    background: rgba(74, 222, 128, 0.15);
    color: #4ade80;
    border: 1px solid rgba(74, 222, 128, 0.3);
}

.badge-role {
    background: rgba(96, 165, 250, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(96, 165, 250, 0.3);
}

.login-btn {
    background-color: #e0e0e0;
    color: #1a1a1a;
    border: none;
    padding: 8px 20px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 14px;
    transition: background-color 0.2s;
    white-space: nowrap;
    font-weight: 500;
}

.login-btn:hover { background-color: #c0c0c0; }

.chat-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

/* ===== WELCOME SCREEN ===== */
.welcome-screen {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    overflow-y: auto;
}

.welcome-content {
    max-width: 800px;
    width: 100%;
    text-align: center;
}

.title-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 12px;
}

.main-logo {
    font-size: 56px;
    font-weight: 300;
    color: #e0e0e0;
    letter-spacing: 2px;
}

.pro-badge {
    color: #4ade80;
    font-weight: 700;
}

.welcome-subtitle {
    font-size: 18px;
    color: #888;
    margin-bottom: 40px;
    font-weight: 300;
}

.feature-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 40px;
}

.feature-card {
    background: #252525;
    border: 1px solid #333;
    border-radius: 16px;
    padding: 24px 16px;
    transition: all 0.3s;
    cursor: default;
}

.feature-card:hover {
    border-color: #4ade80;
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(74, 222, 128, 0.1);
}

.feature-icon {
    font-size: 36px;
    margin-bottom: 12px;
}

.feature-card h3 {
    font-size: 15px;
    color: #e0e0e0;
    margin-bottom: 6px;
    font-weight: 500;
}

.feature-card p {
    font-size: 13px;
    color: #888;
    line-height: 1.5;
}

.quick-start {
    background: #252525;
    border: 1px solid #333;
    border-radius: 16px;
    padding: 24px;
}

.quick-start-title {
    font-size: 14px;
    color: #888;
    margin-bottom: 16px;
}

.quick-start-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
}

.qs-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: #333;
    border: 1px solid #3a3a3a;
    border-radius: 10px;
    color: #e0e0e0;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
}

.qs-btn:hover {
    background: #3d3d3d;
    border-color: #4ade80;
}

/* ===== CHAT MESSAGES ===== */
.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    -webkit-overflow-scrolling: touch;
}

.message {
    display: flex;
    gap: 10px;
    max-width: 860px;
    width: 100%;
    margin: 0 auto;
    animation: fadeIn 0.3s ease-in;
}

.message.ai { align-self: flex-start; flex-direction: row; }
.message.user { align-self: flex-end; flex-direction: row-reverse; margin-left: auto; }

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}

.message-avatar {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-weight: 600;
    font-size: 10px;
    color: #e0e0e0;
    align-self: flex-end;
    margin-bottom: 20px;
}

.message.ai .message-avatar {
    background-color: #2d2d2d;
    border: 1px solid #3a3a3a;
}

.message.user .message-avatar {
    background-color: #3d3d5c;
}

.message-content {
    display: flex;
    flex-direction: column;
    min-width: 0;
    max-width: calc(100% - 40px);
}

.message.ai .message-content { align-items: flex-start; }
.message.user .message-content { align-items: flex-end; }

.message-bubble {
    padding: 12px 16px;
    border-radius: 18px;
    line-height: 1.6;
    font-size: 15px;
    white-space: pre-wrap;
    word-wrap: break-word;
    overflow-wrap: break-word;
    max-width: 100%;
}

.message.ai .message-bubble {
    background-color: #252525;
    color: #e0e0e0;
    border-bottom-left-radius: 4px;
    border: 1px solid #333;
}

.message.user .message-bubble {
    background-color: #3d3d5c;
    color: #e8e8f0;
    border-bottom-right-radius: 4px;
}

.message-meta {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 4px;
}

.message.ai .message-meta { flex-direction: row; }
.message.user .message-meta { flex-direction: row-reverse; }

.message-time {
    font-size: 11px;
    color: #555;
    padding: 0 2px;
}

.copy-btn {
    background: none;
    border: none;
    color: #555;
    cursor: pointer;
    padding: 3px 5px;
    border-radius: 5px;
    display: flex;
    align-items: center;
    opacity: 0;
    transition: opacity 0.15s, color 0.15s, background 0.15s;
    flex-shrink: 0;
}

.message:hover .copy-btn { opacity: 1; }
.copy-btn:hover { color: #e0e0e0; background: #3a3a3a; }

@media (hover: none) {
    .copy-btn { opacity: 0.4; }
}

/* ===== CHAT INPUT ===== */
.chat-input-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 12px 16px 16px;
    width: 100%;
    flex-shrink: 0;
}

.input-wrapper {
    background-color: #252525;
    border-radius: 16px;
    padding: 12px 16px;
    display: flex;
    align-items: flex-end;
    gap: 10px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    border: 1px solid #333;
    transition: border-color 0.2s;
}

.input-wrapper:focus-within {
    border-color: #4ade80;
}

.chat-input {
    flex: 1;
    background: transparent;
    border: none;
    color: #e0e0e0;
    font-size: 16px;
    padding: 10px 0;
    outline: none;
    resize: none;
    max-height: 200px;
    font-family: inherit;
    line-height: 1.5;
    -webkit-appearance: none;
}

.chat-input::placeholder { color: #666; }

.input-options {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
}

.option-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.2s;
    padding: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
}

.option-btn:hover { opacity: 1; }
.option-btn:active { opacity: 1; background: #3a3a3a; }

.send-btn {
    background-color: #4ade80;
    color: #1a1a1a;
    border: none;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
}

.send-btn:hover {
    background-color: #22c55e;
    transform: scale(1.05);
}

.send-btn:active { transform: scale(0.95); }

#attached-file-info {
    display: none;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    padding: 6px 4px 2px;
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
}

#attached-file-info.file-visible { display: flex; }

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: #3a3a3a; border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: #4a4a4a; }

.hidden { display: none !important; }

/* ===== MODALS ===== */
.modal-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
