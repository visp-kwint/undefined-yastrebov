        del.style.cssText = 'background:none;border:none;color:#888;cursor:pointer;font-size:16px;line-height:1;padding:0 2px;flex-shrink:0;';
        del.onmouseover = () => del.style.color = '#ff4444';
        del.onmouseout = () => del.style.color = '#888';
