                    <div class="modal-input-wrapper"><input type="password" class="modal-input" placeholder="Пароль (мин. 4 символа)" id="reg-password"></div>
                    <div class="modal-input-wrapper"><input type="password" class="modal-input" placeholder="Подтвердите пароль" id="reg-password2"></div>
                    <button class="modal-btn" id="register-btn">Зарегистрироваться</button>
