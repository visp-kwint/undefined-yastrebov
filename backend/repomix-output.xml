<file path="CodeSprint-new-main/public/main.css">
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    background-color: #1a1a1a;
    color: #e0e0e0;
    overflow: hidden;
    height: 100vh;
    height: 100dvh;
}

.container {
    display: flex;
    height: 100vh;
    height: 100dvh;
}

/* ===== SIDEBAR ===== */
.sidebar {
    width: 300px;
    background-color: #252525;
    padding: 16px;
    display: flex;
    flex-direction: column;
    border-right: 1px solid #333;
    flex-shrink: 0;
    z-index: 200;
    transition: transform 0.3s ease;
    overflow-y: auto;
}

.sidebar-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid #333;
}

.logo {
    font-size: 22px;
    font-weight: 600;
    color: #e0e0e0;
}

.logo-pro {
    color: #4ade80;
    font-weight: 700;
}

.folder-icon { font-size: 20px; }

/* ===== COMMAND PANEL ===== */
.command-panel {
    background: #2a2a2a;
    border-radius: 12px;
    padding: 14px;
    margin-bottom: 16px;
    border: 1px solid #333;
}

.panel-title {
    font-size: 12px;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 10px;
    font-weight: 600;
}

.command-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
}

.cmd-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 10px 4px;
    background: #333;
    border: 1px solid #3a3a3a;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    color: #b0b0b0;
}

.cmd-btn:hover {
    background: #3d3d3d;
    border-color: #4ade80;
    color: #e0e0e0;
    transform: translateY(-1px);
}

.cmd-btn:active {
    transform: translateY(0);
}

.cmd-icon {
    font-size: 20px;
    line-height: 1;
}

.cmd-label {
    font-size: 10px;
    text-align: center;
    line-height: 1.2;
}

/* ===== QUICK ACTIONS ===== */
.quick-actions {
    background: #2a2a2a;
    border-radius: 12px;
    padding: 14px;
    margin-bottom: 16px;
    border: 1px solid #333;
}

.action-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.action-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    background: #333;
    border: 1px solid #3a3a3a;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    color: #c0c0c0;
    font-size: 13px;
    text-align: left;
    width: 100%;
}

.action-btn:hover {
    background: #3d3d3d;
    border-color: #60a5fa;
    color: #e0e0e0;
}

.action-btn span {
    font-size: 16px;
}

/* ===== SIDEBAR NAV ===== */
.sidebar-nav ul {
    list-style: none;
    margin-bottom: 16px;
}

.sidebar-nav li {
    padding: 10px 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    color: #b0b0b0;
    transition: all 0.2s;
    user-select: none;
    border-radius: 8px;
    margin-bottom: 4px;
    font-size: 14px;
}

.sidebar-nav li:hover {
    color: #e0e0e0;
    background: #2a2a2a;
}

.sidebar-nav li:active {
    color: #ffffff;
    background: #333;
}

.sidebar-nav .icon {
    font-size: 16px;
