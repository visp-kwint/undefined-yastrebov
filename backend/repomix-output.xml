  cursor: pointer;
  color: #aaa;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  transition: color 0.2s;
  text-align: left;
}
.panel-toggle-btn:hover { color: #e0e0e0; }
.panel-title-text { display: flex; align-items: center; gap: 6px; }

/* Chevron rotates on open */
.panel-chevron {
  width: 16px; height: 16px;
  transition: transform 0.25s ease;
  flex-shrink: 0;
  opacity: 0.6;
}
.panel-chevron.open { transform: rotate(180deg); }

/* Panel body — collapsed hides content */
.panel-body {
  padding: 0 12px 12px;
}
.panel-body.collapsed {
  display: none;
}

/* ===== COMMAND GRID ===== */
.command-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
.cmd-btn { display: flex; flex-direction: column; align-items: center; gap: 3px; padding: 8px 4px; background: #333; border: 1px solid #3a3a3a; border-radius: 8px; cursor: pointer; transition: all 0.2s; color: #b0b0b0; }
.cmd-btn:hover { background: #3d3d3d; border-color: #4ade80; color: #e0e0e0; transform: translateY(-1px); }
.cmd-btn:active { transform: translateY(0); }
.cmd-icon { font-size: 18px; line-height: 1; }
.cmd-label { font-size: 10px; text-align: center; line-height: 1.2; }

/* ===== QUICK ACTIONS ===== */
.action-list { display: flex; flex-direction: column; gap: 5px; }
.action-btn { display: flex; align-items: center; gap: 9px; padding: 9px 12px; background: #333; border: 1px solid #3a3a3a; border-radius: 8px; cursor: pointer; transition: all 0.2s; color: #c0c0c0; font-size: 13px; text-align: left; width: 100%; }
.action-btn:hover { background: #3d3d3d; border-color: #60a5fa; color: #e0e0e0; }

/* ===== SIDEBAR NAV ===== */
.sidebar-nav ul { list-style: none; margin-bottom: 12px; }
.sidebar-nav li { padding: 9px 12px; display: flex; align-items: center; gap: 12px; cursor: pointer; color: #b0b0b0; transition: all 0.2s; user-select: none; border-radius: 8px; margin-bottom: 2px; font-size: 14px; }
.sidebar-nav li:hover { color: #e0e0e0; background: #2a2a2a; }
.sidebar-nav .icon { display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

.sidebar-sections { flex: 1; overflow-y: auto; overflow-x: hidden; }
.section { margin-bottom: 16px; }
.section h3 { font-size: 11px; color: #555; margin-bottom: 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
.history-item { padding: 7px 10px; background: #2a2a2a; border-radius: 7px; margin-bottom: 4px; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 6px; border: 1px solid transparent; transition: all 0.15s; }
.history-item:hover { background: #333; border-color: #3a3a3a; }
.history-item-title { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0; }
.history-item-del { background: none; border: none; color: #555; font-size: 15px; cursor: pointer; padding: 0 2px; border-radius: 4px; flex-shrink: 0; opacity: 0; transition: opacity 0.15s, color 0.15s; }
.history-item:hover .history-item-del { opacity: 1; }
.history-item-del:hover { color: #ff4444; }
@media (hover: none) { .history-item-del { opacity: 0.5; } }

.sidebar-footer { display: flex; flex-direction: column; gap: 8px; padding-top: 12px; margin-top: auto; border-top: 1px solid #333; }
.sidebar-footer a { color: #555; text-decoration: none; font-size: 12px; }
.sidebar-footer a:hover { color: #888; }
.sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 199; backdrop-filter: blur(2px); }
.sidebar-overlay.active { display: block; }

/* ===== MAIN ===== */
.burger-btn { display: none; background: none; border: none; cursor: pointer; padding: 8px; border-radius: 8px; color: #e0e0e0; transition: background 0.2s; flex-shrink: 0; }
.burger-btn:hover { background: #3a3a3a; }
.burger-btn svg { display: block; }
.main-content { flex: 1; background: #1a1a1a; display: flex; flex-direction: column; min-width: 0; overflow: hidden; }
.main-header { display: flex; justify-content: space-between; align-items: center; padding: 10px 20px; gap: 12px; flex-shrink: 0; border-bottom: 1px solid #2a2a2a; }
.header-badges { display: flex; gap: 8px; align-items: center; }
.badge { padding: 3px 9px; border-radius: 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
.badge-pro { background: rgba(74,222,128,0.12); color: #4ade80; border: 1px solid rgba(74,222,128,0.3); }
.badge-role { background: rgba(96,165,250,0.12); color: #60a5fa; border: 1px solid rgba(96,165,250,0.3); }
.login-btn { background: #e0e0e0; color: #1a1a1a; border: none; padding: 7px 18px; border-radius: 20px; cursor: pointer; font-size: 14px; font-weight: 500; transition: background 0.2s; white-space: nowrap; }
.login-btn:hover { background: #c0c0c0; }
.chat-container { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

/* ===== WELCOME ===== */
.welcome-screen { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 32px 20px; overflow-y: auto; }
.welcome-content { max-width: 680px; width: 100%; text-align: center; }
.title-wrapper { display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 10px; }
.main-logo { font-size: 52px; font-weight: 300; color: #e0e0e0; letter-spacing: 2px; }
.pro-badge { color: #4ade80; font-weight: 700; }
.welcome-subtitle { font-size: 17px; color: #888; margin-bottom: 32px; font-weight: 300; }
.feature-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 28px; }
.feature-card { background: #252525; border: 1px solid #333; border-radius: 14px; padding: 20px 14px; transition: all 0.3s; }
.feature-card:hover { border-color: #4ade80; transform: translateY(-3px); box-shadow: 0 6px 24px rgba(74,222,128,0.1); }
.feature-icon { font-size: 32px; margin-bottom: 10px; }
.feature-card h3 { font-size: 14px; color: #e0e0e0; margin-bottom: 4px; font-weight: 500; }
.feature-card p { font-size: 12px; color: #888; line-height: 1.5; }
.quick-start { background: #252525; border: 1px solid #333; border-radius: 14px; padding: 20px; }
.quick-start-title { font-size: 13px; color: #888; margin-bottom: 14px; }
.quick-start-buttons { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
.qs-btn { display: flex; align-items: center; gap: 8px; padding: 10px 18px; background: #333; border: 1px solid #3a3a3a; border-radius: 10px; color: #e0e0e0; font-size: 14px; cursor: pointer; transition: all 0.2s; }
.qs-btn:hover { background: #3d3d3d; border-color: #4ade80; }

/* ===== CHAT MESSAGES — narrower + tighter ===== */
.chat-messages {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  display: flex;
  flex-direction: column;
  /* Reduced gap: was 16px */
  gap: 8px;
  padding: 16px 0;
  align-items: center;
  -webkit-overflow-scrolling: touch;
}

/* Reduced max-width from 720px → 560px */
.message {
  display: flex;
  gap: 8px;
  width: 100%;
  max-width: 1000px;
  padding: 0 16px;
  animation: fadeIn 0.25s ease-in;
  box-sizing: border-box;
}
.message.ai { flex-direction: row; }
.message.user { flex-direction: row-reverse; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

.message-avatar { width: 26px; height: 26px; border-radius: 7px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-weight: 600; font-size: 9px; color: #e0e0e0; align-self: flex-end; margin-bottom: 18px; }
.message.ai .message-avatar { background: #2d2d2d; border: 1px solid #3a3a3a; }
.message.user .message-avatar { background: #3d3d5c; }
.message-content { display: flex; flex-direction: column; min-width: 0; max-width: calc(100% - 36px); }
.message.ai .message-content { align-items: flex-start; }
.message.user .message-content { align-items: flex-end; }

.message-bubble { padding: 10px 14px; border-radius: 16px; line-height: 1.55; font-size: 14px; word-wrap: break-word; overflow-wrap: break-word; max-width: 100%; }
.message.ai .message-bubble { background: #252525; color: #e0e0e0; border-bottom-left-radius: 3px; border: 1px solid #333; }
.message.user .message-bubble { background: #3d3d5c; color: #e8e8f0; border-bottom-right-radius: 3px; }
/* Style AI text elements */
.message.ai .message-bubble strong { color: #f0f0f0; }
.message.ai .message-bubble .ai-section-header { color: #4ade80; font-weight: 600; display: block; margin: 6px 0 2px; border-bottom: 1px solid #2a2a2a; padding-bottom: 3px; }
.message.ai .message-bubble hr { border: none; border-top: 1px solid #333; margin: 6px 0; }

.message-meta { display: flex; align-items: center; gap: 4px; margin-top: 3px; }
.message.ai .message-meta { flex-direction: row; }
.message.user .message-meta { flex-direction: row-reverse; }
.message-time { font-size: 10px; color: #555; padding: 0 2px; }
.copy-btn { background: none; border: none; color: #555; cursor: pointer; padding: 3px 5px; border-radius: 5px; display: flex; align-items: center; opacity: 0; transition: opacity 0.15s, color 0.15s; flex-shrink: 0; }
.message:hover .copy-btn { opacity: 1; }
.copy-btn:hover { color: #e0e0e0; background: #3a3a3a; }
@media (hover: none) { .copy-btn { opacity: 0.4; } }

/* ===== FILE CHIPS ===== */
.msg-file-chips { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 5px; width: 100%; justify-content: flex-end; }
.msg-file-chip { display: inline-flex; align-items: center; gap: 5px; background: rgba(74,222,128,0.07); border: 1px solid rgba(74,222,128,0.18); border-radius: 9px; padding: 4px 9px; font-size: 12px; color: #a0c0a0; max-width: 220px; }
.msg-chip-icon { font-size: 13px; flex-shrink: 0; }
.msg-chip-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; color: #c8e0c8; }
.msg-chip-size { opacity: 0.5; font-size: 11px; flex-shrink: 0; white-space: nowrap; }

/* ===== CHAT INPUT — matches narrower chat ===== */
.chat-input-container { max-width: 800px; width: 100%; margin: 0 auto; padding: 6px 16px 14px; flex-shrink: 0; }

.attached-files-bar { display: flex; flex-direction: row; flex-wrap: wrap; align-items: center; gap: 5px; padding: 0 2px 7px; }
.attached-file-chip { display: flex; align-items: center; gap: 5px; background: #2a2a2a; border: 1px solid #3a3a3a; border-radius: 9px; padding: 4px 9px; font-size: 13px; color: #c0c0c0; max-width: 200px; }
.attached-file-chip:hover { border-color: #4ade80; }
.chip-icon { flex-shrink: 0; font-size: 13px; }
.chip-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
.chip-remove { background: none; border: none; color: #555; cursor: pointer; font-size: 15px; line-height: 1; padding: 0; flex-shrink: 0; width: 18px; height: 18px; border-radius: 4px; display: flex; align-items: center; justify-content: center; transition: color 0.15s; }
.chip-remove:hover { color: #ff4444; }
.attached-files-count { font-size: 11px; color: #666; }

.input-wrapper { background: #252525; border-radius: 14px; padding: 10px 14px; display: flex; align-items: flex-end; gap: 8px; box-shadow: 0 4px 16px rgba(0,0,0,0.3); border: 1px solid #333; transition: border-color 0.2s; }
.input-wrapper:focus-within { border-color: #4ade80; }
.chat-input { flex: 1; background: transparent; border: none; color: #e0e0e0; font-size: 15px; padding: 8px 0; outline: none; resize: none; max-height: 200px; font-family: inherit; line-height: 1.5; -webkit-appearance: none; }
.chat-input::placeholder { color: #666; }
.input-options { display: flex; gap: 2px; flex-shrink: 0; }
.option-btn { background: transparent; border: none; cursor: pointer; opacity: 0.55; transition: opacity 0.2s; padding: 5px; display: flex; align-items: center; justify-content: center; border-radius: 7px; }
.option-btn:hover { opacity: 1; background: #333; }
.send-btn { background: #4ade80; color: #1a1a1a; border: none; width: 38px; height: 38px; border-radius: 10px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; flex-shrink: 0; }
.send-btn:hover { background: #22c55e; transform: scale(1.05); }
.send-btn:active { transform: scale(0.95); }

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: #3a3a3a; border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: #4a4a4a; }
.hidden { display: none !important; }

/* ===== MODALS ===== */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px); padding: 16px; }
.modal-container { background: #252525; border-radius: 20px; padding: 30px 26px; max-width: 460px; width: 100%; position: relative; box-shadow: 0 20px 60px rgba(0,0,0,0.5); max-height: 90vh; overflow-y: auto; border: 1px solid #333; }
.modal-close { position: absolute; top: 14px; right: 14px; background: transparent; border: none; color: #888; font-size: 26px; cursor: pointer; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; border-radius: 50%; transition: all 0.2s; }
.modal-close:hover { color: #e0e0e0; background: #3a3a3a; }
.modal-content { text-align: center; }
.modal-title { font-size: 20px; font-weight: 400; color: #e0e0e0; margin-bottom: 8px; }
.modal-subtitle { font-size: 14px; color: #888; line-height: 1.6; margin-bottom: 22px; }
.modal-tabs { display: flex; border-bottom: 1px solid #333; margin-bottom: 22px; }
.modal-tab { flex: 1; padding: 10px; background: none; border: none; color: #666; font-size: 15px; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; margin-bottom: -1px; }
.modal-tab:hover { color: #e0e0e0; }
.modal-tab.active { color: #e0e0e0; border-bottom-color: #4ade80; }
.tab-panel { display: none; }
.tab-panel.active { display: block; }
.auth-message { font-size: 13px; margin-bottom: 12px; border-radius: 8px; padding: 8px 12px; }
.auth-message.error { color: #ff6b6b; background: #ff44441a; border: 1px solid rgba(255,68,68,0.25); }
.auth-message.success { color: #4ade80; background: #4ade801a; border: 1px solid rgba(74,222,128,0.25); }
.btn-spinner { display: inline-block; width: 13px; height: 13px; border: 2px solid rgba(0,0,0,0.3); border-top-color: #1a1a1a; border-radius: 50%; animation: spin 0.6s linear infinite; margin-right: 7px; vertical-align: middle; }
@keyframes spin { to { transform: rotate(360deg); } }
.modal-input-wrapper { margin-bottom: 12px; }
.modal-input { width: 100%; padding: 13px 16px; background: #1a1a1a; border: 1px solid #333; border-radius: 11px; color: #e0e0e0; font-size: 15px; outline: none; transition: border-color 0.2s; -webkit-appearance: none; }
.modal-input:focus { border-color: #4ade80; }
.modal-input::placeholder { color: #666; }
.modal-btn { width: 100%; padding: 13px; background: #e0e0e0; color: #1a1a1a; border: none; border-radius: 11px; font-size: 15px; font-weight: 500; cursor: pointer; transition: all 0.2s; margin-bottom: 12px; display: flex; align-items: center; justify-content: center; }
.modal-btn:hover { background: #c0c0c0; transform: translateY(-1px); }
.modal-btn:active { transform: translateY(0); }
.modal-btn:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

.user-profile { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 9px 14px; background: #333; border-radius: 8px; font-size: 13px; color: #e0e0e0; width: 100%; cursor: pointer; transition: background 0.2s; }
.user-profile:hover { background: #3d3d3d; }
.user-avatar { width: 26px; height: 26px; border-radius: 50%; background: #4a4a4a; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.user-email { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; text-align: center; }
.footer-links { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 8px 12px; padding-top: 8px; border-top: 1px solid #333; }
.footer-links a { color: #555; text-decoration: none; font-size: 12px; transition: color 0.2s; }
.footer-links a:hover { color: #888; }

.profile-modal-container { background: #252525; border-radius: 20px; padding: 30px 26px; max-width: 340px; width: 100%; position: relative; box-shadow: 0 20px 60px rgba(0,0,0,0.5); text-align: center; border: 1px solid #333; }
.profile-header { margin-bottom: 24px; }
.profile-avatar-large { width: 60px; height: 60px; border-radius: 50%; background: #3a3a3a; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; }
.profile-email { font-size: 15px; color: #e0e0e0; font-weight: 500; word-break: break-all; }
.profile-actions { display: flex; flex-direction: column; gap: 10px; }
.profile-btn { width: 100%; padding: 13px 18px; border-radius: 11px; font-size: 14px; font-weight: 500; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 9px; border: 1px solid transparent; }
.sign-out-btn { background: #e0e0e0; color: #1a1a1a; }
.sign-out-btn:hover { background: #c0c0c0; }
.delete-account-btn { background: transparent; color: #ff4444; border: 1px solid #333; }
.delete-account-btn:hover { background: #ff44441a; border-color: #ff4444; }
.delete-confirm-actions { display: flex; gap: 10px; margin-top: 22px; }
.delete-confirm-actions .modal-btn { flex: 1; margin-bottom: 0; }
.cancel-btn { background: #333 !important; color: #e0e0e0 !important; }
.cancel-btn:hover { background: #3d3d3d !important; }
.delete-confirm-btn { background: #ff4444 !important; color: white !important; }
.delete-confirm-btn:hover { background: #ff3333 !important; }

.toast { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%) translateY(20px); background: #333; color: #e0e0e0; padding: 11px 22px; border-radius: 11px; font-size: 14px; opacity: 0; pointer-events: none; transition: all 0.3s ease; z-index: 9999; box-shadow: 0 4px 20px rgba(0,0,0,0.4); max-width: calc(100vw - 32px); text-align: center; border: 1px solid #444; }
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
.toast.success { background: #1a3a2a; border-color: #4ade80; color: #4ade80; }
.toast.error { background: #3a1a1a; border-color: #ff4444; color: #ff4444; }

/* ===== REPORT STYLES ===== */
.report-card { background: #252525; border: 1px solid #333; border-radius: 11px; padding: 18px; margin: 8px 0; max-width: 100%; }
.report-header { border-bottom: 2px solid #3a3a3a; padding-bottom: 9px; margin-bottom: 13px; }
.report-title { color: #e0e0e0; font-size: 17px; margin: 0; }
.report-text { color: #b0b0b0; font-size: 13px; margin-bottom: 8px; line-height: 1.6; }
.report-subtitle { color: #4ade80; font-size: 14px; margin: 12px 0 6px; font-weight: 600; display: block; }
.report-code { background: #1a1a1a; border: 1px solid #333; border-radius: 7px; padding: 11px 14px; overflow-x: auto; font-family: 'SF Mono', Monaco, Consolas, monospace; font-size: 12px; line-height: 1.5; color: #e0e0e0; margin: 8px 0; }
.report-table-container { margin: 12px 0; overflow-x: auto; }
.report-table-title { color: #d0d0d0; font-size: 13px; margin-bottom: 7px; font-weight: 600; }
.report-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.report-table th { background: #333; color: #e0e0e0; padding: 9px; text-align: left; border: 1px solid #444; }
.report-table td { padding: 7px 9px; border: 1px solid #2e2e2e; color: #c0c0c0; }
.report-table tr:nth-child(even) { background: #1f1f1f; }
.report-total td { background: #333; color: #e0e0e0; font-weight: bold; }
.report-image-container { margin: 16px 0; text-align: center; }
.report-image-wrapper { display: inline-block; max-width: 100%; border-radius: 10px; overflow: hidden; background: #1a1a1a; border: 1px solid #3a3a3a; box-shadow: 0 4px 16px rgba(0,0,0,0.4); }
.report-image { display: block; max-width: 100%; height: auto; max-height: 460px; object-fit: contain; }
.report-image-caption { margin-top: 8px; font-size: 12px; color: #888; }
.message-bubble img { display: block; max-width: 100%; height: auto; max-height: 400px; object-fit: contain; border-radius: 7px; border: 1px solid #333; margin: 8px 0; background: #1a1a1a; }
.ascii-chart { background: #1a1a1a; border: 1px solid #333; border-radius: 10px; padding: 12px 16px; margin: 10px 0; overflow-x: auto; font-family: 'SF Mono', Monaco, Consolas, monospace; font-size: 12px; line-height: 1.7; color: #c0c0c0; }
.ascii-chart pre { margin: 0; padding: 0; background: none; border: none; font-family: inherit; font-size: inherit; white-space: pre; }
.report-attachments { margin-top: 12px; padding-top: 12px; border-top: 1px solid #333; }
.report-attachments-title { color: #d0d0d0; font-size: 13px; margin-bottom: 8px; }
.report-files { display: flex; flex-wrap: wrap; gap: 8px; }
.report-file-link { display: flex; align-items: center; gap: 7px; background: #333; color: #e0e0e0; text-decoration: none; padding: 7px 11px; border-radius: 6px; font-size: 13px; transition: background 0.2s; }
.report-file-link:hover { background: #3d3d3d; }
.doc-preview-actions { display: flex; gap: 7px; flex-wrap: wrap; margin-top: 9px; }
.doc-preview-actions button { padding: 7px 12px; background: #333; border: 1px solid #444; border-radius: 7px; color: #e0e0e0; font-size: 13px; cursor: pointer; transition: all 0.2s; }
.doc-preview-actions button:hover { background: #3d3d3d; border-color: #4ade80; }

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .sidebar { width: 280px; }
  .message { max-width: 100%; padding: 0 14px; }
