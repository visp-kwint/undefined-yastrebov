  inset: 0;
  background:
  radial-gradient(circle at 15% 20%, rgba(74, 222, 128, 0.06) 0%, transparent 40%),
  radial-gradient(circle at 85% 80%, rgba(96, 165, 250, 0.05) 0%, transparent 40%),
  radial-gradient(circle at 50% 50%, rgba(167, 139, 250, 0.03) 0%, transparent 50%);
