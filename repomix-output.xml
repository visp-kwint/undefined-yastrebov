    <!-- Delete Confirm Modal -->
    <div class="modal-overlay hidden" id="delete-confirm-modal">
        <div class="modal-container">
            <button class="modal-close" id="delete-confirm-close">&times;</button>
            <div class="modal-content">
                <h2 class="modal-title">Удалить аккаунт?</h2>
                <p class="modal-subtitle">Это действие нельзя отменить. Все данные будут удалены.</p>
                <div class="delete-confirm-actions">
                    <button class="modal-btn cancel-btn" id="cancel-delete-btn">Отмена</button>
                    <button class="modal-btn delete-confirm-btn" id="confirm-delete-btn">Удалить</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div class="toast" id="toast"></div>

    <script src="/report-renderer.js"></script>
    <script src="/app.js"></script>
</body>
</html>
</file>

